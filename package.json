{
  "name": "davidtech-updater",
  "version": "0.2.0",
  "description": "Auto-update control plane for DavidTech apps. Registry-based CLI + Cloudflare Worker behind updates.davidtechllc.com.",
  "type": "module",
  "bin": {
    "davidtech-updater": "bin/davidtech-updater.js"
  },
  "files": [
    "bin",
    "src",
    "apps.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "help": "node bin/davidtech-updater.js --help",
    "register": "node bin/davidtech-updater.js register",
    "publish": "node bin/davidtech-updater.js publish",
    "apps": "node bin/davidtech-updater.js apps",
    "slug": "node bin/davidtech-updater.js slug"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mark2messmore/davidtech-updater.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "wrangler": ">=4"
  },
  "peerDependenciesMeta": {
    "wrangler": {
      "optional": true
    }
  }
}
