{
  "name": "davidtech-updater",
  "version": "0.4.0",
  "description": "AI-driven auto-update control plane for DavidTech apps. Local builds, R2 publish, no CI required.",
  "type": "module",
  "bin": {
    "davidtech-updater": "bin/davidtech-updater.js"
  },
  "files": [
    "bin",
    "src",
    "apps.json",
    "README.md",
    "RELEASES.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "help": "node bin/davidtech-updater.js --help",
    "apps": "node bin/davidtech-updater.js apps",
    "register": "node bin/davidtech-updater.js register",
    "set-path": "node bin/davidtech-updater.js set-path",
    "bump": "node bin/davidtech-updater.js bump",
    "publish": "node bin/davidtech-updater.js publish",
    "slug": "node bin/davidtech-updater.js slug"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mark2messmore/davidtech-updater.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "wrangler": ">=4"
  },
  "peerDependenciesMeta": {
    "wrangler": {
      "optional": true
    }
  }
}
